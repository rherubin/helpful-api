# Environment variables for Railway deployment
JWT_SECRET=your-secret-key-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-key-change-in-production

PORT=9000
# DEFAULT_STEPS_REQUIRED_FOR_UNLOCK=7  # Uncomment and set to override the default of 0

OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-5.4

# Set TEST_MOCK_LLM=true to return deterministic mock LLM responses from
# the server so tests never spend real tokens.
# TEST_MOCK_LLM=true

# MySQL Database Configuration (for local development)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=helpful_local_root_2024
MYSQL_DATABASE=helpful_db

# Or use a single MySQL URL (Railway format)
# MYSQL_URL=mysql://root:helpful_local_root_2024@localhost:3306/helpful_db
